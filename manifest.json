{
  "manifest_version": 2,
  "name": "Claude Hide Chats",
  "version": "1.0",
  "description": "Hide chats that belong to projects in Claude's sidebar",
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-hide-chats@firefox-addon",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
